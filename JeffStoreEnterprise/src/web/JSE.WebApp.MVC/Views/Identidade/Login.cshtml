@model JSE.WebApp.MVC.Models.UsuarioLoginViewModel

@{
    ViewData["Title"] = "Entrar";
}

<div class="container  align-items-center mt-4">
    <div class="col-4 w-25 m-auto">
        <h2 class="h2 mt-auto">Entrar</h2>
       
        <div class="nav fs-sm mb-4">
            Não é cadastrado?
            <a class="nav-link text-decoration-underline p-0 ms-2" asp-action="Registro" asp-controller="Identidade">Cadastre-se</a>
        </div>

        <form class="needs-validation" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" autocomplete="off">
            
            <vc:Summary></vc:Summary>

            <div class="position-relative mb-4">
                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="E-mail" autocomplete="new-text" required />
                <span asp-validation-for="Email" class="invalid-tooltip bg-transparent py-0"></span> 
            </div>
           
            <div class="mb-4">
                <div class="password-toggle">
                    <input asp-for="Senha" type="password" class="form-control form-control-lg" placeholder="Senha" required>
                    <span asp-validation-for="Senha" class="invalid-tooltip bg-transparent py-0"></span>
                    <label asp-for="Senha" class="password-toggle-button fs-lg" aria-label="Show/hide password">
                        <input type="checkbox" class="btn-check">
                    </label>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
               
                <div class="form-check me-2">
                    <input type="checkbox" class="form-check-input" id="remember-30">
                    <label for="remember-30" class="form-check-label">Lembrar</label>
                </div>

                <div class="nav">
                    <a class="nav-link animate-underline p-0" href="/">
                        <span class="animate-target">Esqueceu a senha?</span>
                    </a>
                </div>

            </div>

            <button type="submit" class="btn btn-lg btn-primary w-100">Entrar</button>

        </form>

        <div class="d-flex align-items-center my-4">
            <hr class="w-100 m-0">
            <span class="text-body-emphasis fw-medium text-nowrap mx-4">ou continue com</span>
            <hr class="w-100 m-0">
        </div>

        <div class="d-flex flex-column flex-sm-row gap-3 pb-4 mb-3 mb-lg-4">
            <button type="button" class="btn btn-lg btn-outline-secondary w-100 px-2">
                <i class="ci-google ms-1 me-1"></i>
                Google
            </button>
            <button type="button" class="btn btn-lg btn-outline-secondary w-100 px-2">
                <i class="ci-facebook ms-1 me-1"></i>
                Facebook
            </button>
            <button type="button" class="btn btn-lg btn-outline-secondary w-100 px-2">
                <i class="ci-apple ms-1 me-1"></i>
                Apple
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
